rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.platformRole == 'superAdmin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    function hasPermission(entityId, permission) {
      let membershipId = request.auth.uid + "_" + entityId;
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/memberships/$(membershipId)) &&
        get(/databases/$(database)/documents/memberships/$(membershipId)).data.status == 'active' &&
        permission in get(/databases/$(database)/documents/memberships/$(membershipId)).data.permissions;
    }

    // --- Public Collection Group Rules ---
    
    match /{path=**}/applicationForms/{formId} {
      allow read: if resource.data.status == 'published';
    }

    // --- Platform Level Rules ---

    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isPlatformAdmin());
      allow write: if isPlatformAdmin();
    }

    match /memberships/{membershipId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isPlatformAdmin());
      allow write: if isPlatformAdmin();
    }

    match /publicOfferTokens/{tokenHash} {
      // Secure tokens are strictly handled by Admin SDK server-side
      allow read, write: if false;
    }

    match /entities/{entityId} {
      allow read: if isAuthenticated() && (hasPermission(entityId, 'dashboard.read') || isPlatformAdmin());
      allow write: if isPlatformAdmin();

      // --- Entity Specific Sub-collections ---

      match /persons/{personId} {
        allow read: if hasPermission(entityId, 'persons.read') || isPlatformAdmin();
        allow write: if hasPermission(entityId, 'persons.create') || hasPermission(entityId, 'persons.update') || isPlatformAdmin();
      }

      match /candidates/{candidateId} {
        allow read: if hasPermission(entityId, 'candidates.read') || isPlatformAdmin();
        allow write: if hasPermission(entityId, 'candidates.create') || hasPermission(entityId, 'candidates.update') || hasPermission(entityId, 'candidates.decide') || isPlatformAdmin();
      }

      match /candidateViews/{viewId} {
        allow read: if hasPermission(entityId, 'candidates.read') || isPlatformAdmin();
        allow write: if hasPermission(entityId, 'candidates.decide') || hasPermission(entityId, 'candidates.update') || isPlatformAdmin();
      }

      match /interviews/{interviewId} {
        allow read: if hasPermission(entityId, 'interviews.read') || isPlatformAdmin();
        allow write: if hasPermission(entityId, 'interviews.create') || hasPermission(entityId, 'interviews.update') || hasPermission(entityId, 'interviews.decide') || isPlatformAdmin();
      }

      match /employmentOffers/{offerId} {
        allow read: if hasPermission(entityId, 'contracts.read') || hasPermission(entityId, 'candidates.read') || isPlatformAdmin();
        allow write: if hasPermission(entityId, 'contracts.create') || isPlatformAdmin();
      }

      match /emailLogs/{logId} {
        allow read: if hasPermission(entityId, 'interviews.read') || hasPermission(entityId, 'interviews.notify') || isPlatformAdmin();
        allow create: if hasPermission(entityId, 'interviews.create') || hasPermission(entityId, 'interviews.notify') || isPlatformAdmin();
        allow update: if isPlatformAdmin();
      }

      match /departments/{departmentId} {
        allow read: if hasPermission(entityId, 'departments.read') || isPlatformAdmin();
        allow write: if hasPermission(entityId, 'departments.update') || isPlatformAdmin();
      }

      match /worksites/{worksiteId} {
        allow read: if hasPermission(entityId, 'worksites.read') || isPlatformAdmin();
        allow create: if hasPermission(entityId, 'worksites.create') || isPlatformAdmin();
        allow update: if hasPermission(entityId, 'worksites.update') || hasPermission(entityId, 'worksites.archive') || isPlatformAdmin();
        allow delete: if false;
      }

      match /jobTitles/{jobId} {
        allow read: if hasPermission(entityId, 'jobTitles.read') || isPlatformAdmin();
        allow write: if hasPermission(entityId, 'jobTitles.update') || isPlatformAdmin();
      }

      match /jobProfiles/{profileId} {
        allow read: if hasPermission(entityId, 'jobProfiles.read') || isPlatformAdmin();
        allow write: if hasPermission(entityId, 'jobProfiles.create') || hasPermission(entityId, 'jobProfiles.update') || isPlatformAdmin();
        
        match /versions/{versionId} {
          allow read: if hasPermission(entityId, 'jobProfiles.read') || isPlatformAdmin();
          allow write: if hasPermission(entityId, 'jobProfiles.update') || isPlatformAdmin();
        }
      }

      match /jobProfileCatalogItems/{itemId} {
        allow read: if hasPermission(entityId, 'jobProfileCatalog.read') || isPlatformAdmin();
        allow write: if hasPermission(entityId, 'jobProfileCatalog.create') || hasPermission(entityId, 'jobProfileCatalog.update') || isPlatformAdmin();
      }

      match /recruitmentNeeds/{needId} {
        allow read: if hasPermission(entityId, 'recruitmentNeeds.read') || isPlatformAdmin() || (request.auth == null && resource.data.status in ['open', 'partially_fulfilled']);
        allow write: if hasPermission(entityId, 'recruitmentNeeds.create') || hasPermission(entityId, 'recruitmentNeeds.update') || hasPermission(entityId, 'recruitmentNeeds.cancel') || isPlatformAdmin();
      }

      match /applicationForms/{formId} {
        allow read: if hasPermission(entityId, 'applicationForms.read') || isPlatformAdmin() || (request.auth == null && resource.data.status == 'published');
        allow create: if hasPermission(entityId, 'applicationForms.create') || isPlatformAdmin();
        allow update: if hasPermission(entityId, 'applicationForms.update') || hasPermission(entityId, 'applicationForms.publish') || isPlatformAdmin();
      }

      match /applicationSubmissions/{submissionId} {
        allow read: if hasPermission(entityId, 'applicationSubmissions.read') || isPlatformAdmin();
        allow write: if isPlatformAdmin();
      }

      match /applicationSubmissionDedupe/{dedupeKey} {
        allow read: if hasPermission(entityId, 'applicationSubmissions.read') || isPlatformAdmin();
        allow write: if isPlatformAdmin();
      }
      
      match /personTimeline/{eventId} {
        allow read: if hasPermission(entityId, 'persons.read') || isPlatformAdmin();
        allow write: if hasPermission(entityId, 'candidates.decide') || hasPermission(entityId, 'candidates.update') || hasPermission(entityId, 'persons.update') || hasPermission(entityId, 'interviews.create') || isPlatformAdmin();
      }

      match /ccnls/{ccnlId} {
        allow read: if hasPermission(entityId, 'settings.read') || 
                     hasPermission(entityId, 'settings.manage') ||
                     hasPermission(entityId, 'jobProfiles.read') || 
                     hasPermission(entityId, 'jobProfiles.create') || 
                     hasPermission(entityId, 'jobProfiles.update') ||
                     hasPermission(entityId, 'contracts.read') ||
                     hasPermission(entityId, 'contracts.create') ||
                     isPlatformAdmin();
        allow write: if hasPermission(entityId, 'settings.manage') || isPlatformAdmin();

        match /levels/{levelId} {
          allow read: if hasPermission(entityId, 'settings.read') || 
                       hasPermission(entityId, 'settings.manage') ||
                       hasPermission(entityId, 'jobProfiles.read') || 
                       hasPermission(entityId, 'jobProfiles.create') || 
                       hasPermission(entityId, 'jobProfiles.update') ||
                       hasPermission(entityId, 'contracts.read') ||
                       hasPermission(entityId, 'contracts.create') ||
                       isPlatformAdmin();
          allow write: if hasPermission(entityId, 'settings.manage') || isPlatformAdmin();
        }
      }
    }

    // --- Global Reference Data ---

    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin();
    }

    match /permissions/{code} {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isPlatformAdmin();
      allow create: if isAuthenticated();
    }
    
    // --- Standard Debug Collection ---
    match /debug/{id} {
      allow read, write: if isAuthenticated();
    }
  }
}
