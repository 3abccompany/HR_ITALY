{
  "entities": {
    "AppUser": {
      "title": "AppUser",
      "description": "Platform-level user profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "platformRole": { "type": "string", "enum": ["superAdmin", "user"] },
        "status": { "type": "string", "enum": ["active", "inactive", "archived"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" },
        "updatedBy": { "type": "string" },
        "disabledAt": { "type": "object" },
        "disabledBy": { "type": "string" },
        "reactivatedAt": { "type": "object" },
        "reactivatedBy": { "type": "string" }
      },
      "required": ["uid", "email", "platformRole", "status"]
    },
    "Membership": {
      "title": "Membership",
      "description": "Link between a user and an entity with a specific role and effective permissions.",
      "type": "object",
      "properties": {
        "membershipId": { "type": "string" },
        "uid": { "type": "string" },
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "userEmail": { "type": "string" },
        "entityId": { "type": "string" },
        "entityName": { "type": "string" },
        "roleId": { "type": "string" },
        "roleLabel": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "inactive", "archived"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" },
        "updatedBy": { "type": "string" },
        "disabledAt": { "type": "object" },
        "disabledBy": { "type": "string" },
        "reactivatedAt": { "type": "object" },
        "reactivatedBy": { "type": "string" }
      },
      "required": ["membershipId", "uid", "entityId", "roleId", "status", "permissions"]
    },
    "Entity": {
      "title": "Entity",
      "description": "An organization or company in the system.",
      "type": "object",
      "properties": {
        "entityId": { "type": "string" },
        "nomEntreprise": { "type": "string" },
        "raisonSociale": { "type": "string" },
        "name": { "type": "string" },
        "legalName": { "type": "string" },
        "numeroTVA": { "type": "string" },
        "codeFiscalEntreprise": { "type": "string" },
        "adresseSiegeSocial": { "type": "string" },
        "codePostal": { "type": "string" },
        "ville": { "type": "string" },
        "province": { "type": "string" },
        "telephone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "pec": { "type": "string" },
        "referentEntreprise": { "type": "string" },
        "type": { "type": "string", "enum": ["internal_entity", "supplier", "customer", "other"] },
        "status": { "type": "string", "enum": ["active", "inactive", "archived"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" },
        "updatedBy": { "type": "string" },
        "disabledAt": { "type": "object" },
        "disabledBy": { "type": "string" },
        "reactivatedAt": { "type": "object" },
        "reactivatedBy": { "type": "string" }
      },
      "required": ["entityId", "type", "status", "nomEntreprise", "raisonSociale"]
    },
    "Permission": {
      "title": "Permission",
      "description": "System permission definition.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "module": { "type": "string" },
        "action": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "scope": { "type": "string", "enum": ["platform", "entity"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" },
        "updatedBy": { "type": "string" }
      },
      "required": ["code", "module", "action", "label", "scope", "status"]
    },
    "Role": {
      "title": "Role",
      "description": "Role template defining a set of permissions.",
      "type": "object",
      "properties": {
        "roleId": { "type": "string" },
        "name": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "scope": { "type": "string", "enum": ["platform", "entity"] },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" },
        "updatedBy": { "type": "string" }
      },
      "required": ["roleId", "name", "label", "scope", "permissions", "status"]
    },
    "Person": {
      "title": "Person",
      "description": "Core identity for candidates and employees.",
      "type": "object",
      "properties": {
        "personId": { "type": "string" },
        "entityId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "codiceFiscale": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "currentLifecycleStatus": { "type": "string", "enum": ["person", "candidate", "employee", "former_employee", "archived"] },
        "status": { "type": "string", "enum": ["active", "inactive", "archived"] },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" },
        "updatedBy": { "type": "string" }
      },
      "required": ["personId", "entityId", "firstName", "lastName", "email", "currentLifecycleStatus", "status"]
    },
    "PersonTimeline": {
      "title": "PersonTimeline",
      "description": "History of events for a person within an entity.",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "entityId": { "type": "string" },
        "personId": { "type": "string" },
        "type": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "sourceCollection": { "type": "string" },
        "sourceId": { "type": "string" },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" }
      },
      "required": ["eventId", "entityId", "personId", "type", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "#/entities/AppUser" },
      "description": "User profile data."
    },
    "/memberships/{membershipId}": {
      "schema": { "$ref": "#/entities/Membership" },
      "description": "User memberships to entities."
    },
    "/entities/{entityId}": {
      "schema": { "$ref": "#/entities/Entity" },
      "description": "Entity details."
    },
    "/permissions/{code}": {
      "schema": { "$ref": "#/entities/Permission" },
      "description": "System permissions catalogue."
    },
    "/roles/{roleId}": {
      "schema": { "$ref": "#/entities/Role" },
      "description": "Role templates catalogue."
    },
    "/entities/{entityId}/persons/{personId}": {
      "schema": { "$ref": "#/entities/Person" },
      "description": "Persons belonging to an entity."
    },
    "/entities/{entityId}/personTimeline/{eventId}": {
      "schema": { "$ref": "#/entities/PersonTimeline" },
      "description": "Event logs for a specific person."
    }
  }
}
