{
  "entities": {
    "AppUser": {
      "title": "AppUser",
      "description": "Platform-level user profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "platformRole": { "type": "string", "enum": ["superAdmin", "user"] },
        "status": { "type": "string", "enum": ["active", "inactive", "archived"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" },
        "updatedBy": { "type": "string" },
        "disabledAt": { "type": "object" },
        "disabledBy": { "type": "string" },
        "reactivatedAt": { "type": "object" },
        "reactivatedBy": { "type": "string" }
      },
      "required": ["uid", "email", "platformRole", "status"]
    },
    "Membership": {
      "title": "Membership",
      "description": "Link between a user and an entity with a specific role and effective permissions.",
      "type": "object",
      "properties": {
        "membershipId": { "type": "string" },
        "uid": { "type": "string" },
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "userEmail": { "type": "string" },
        "entityId": { "type": "string" },
        "entityName": { "type": "string" },
        "roleId": { "type": "string" },
        "roleLabel": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "inactive", "archived"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" },
        "updatedBy": { "type": "string" },
        "disabledAt": { "type": "object" },
        "disabledBy": { "type": "string" },
        "reactivatedAt": { "type": "object" },
        "reactivatedBy": { "type": "string" }
      },
      "required": ["membershipId", "uid", "entityId", "roleId", "status", "permissions"]
    },
    "Entity": {
      "title": "Entity",
      "description": "An organization or company in the system.",
      "type": "object",
      "properties": {
        "entityId": { "type": "string" },
        "nomEntreprise": { "type": "string" },
        "raisonSociale": { "type": "string" },
        "name": { "type": "string" },
        "legalName": { "type": "string" },
        "numeroTVA": { "type": "string" },
        "codeFiscalEntreprise": { "type": "string" },
        "adresseSiegeSocial": { "type": "string" },
        "codePostal": { "type": "string" },
        "ville": { "type": "string" },
        "province": { "type": "string" },
        "telephone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "pec": { "type": "string" },
        "referentEntreprise": { "type": "string" },
        "type": { "type": "string", "enum": ["internal_entity", "supplier", "customer", "other"] },
        "status": { "type": "string", "enum": ["active", "inactive", "archived"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "object" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "object" },
        "updatedBy": { "type": "string" },
        "disabledAt": { "type": "object" },
        "disabledBy": { "type": "string" },
        "reactivatedAt": { "type": "object" },
        "reactivatedBy": { "type": "string" }
      },
      "required": ["entityId", "type", "status", "nomEntreprise", "raisonSociale"]
    },
    "ApplicationForm": {
      "title": "ApplicationForm",
      "description": "Configurable candidate application form.",
      "type": "object",
      "properties": {
        "formId": { "type": "string" },
        "entityId": { "type": "string" },
        "recruitmentNeedId": { "type": "string" },
        "publicSlug": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "closed", "archived"] },
        "fields": { "type": "array" }
      }
    },
    "ApplicationSubmission": {
      "title": "ApplicationSubmission",
      "description": "Raw data from a candidate application.",
      "type": "object",
      "properties": {
        "submissionId": { "type": "string" },
        "entityId": { "type": "string" },
        "formId": { "type": "string" },
        "recruitmentNeedId": { "type": "string" },
        "personId": { "type": "string" },
        "candidateId": { "type": "string" },
        "status": { "type": "string" },
        "submittedAt": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "#/entities/AppUser" },
      "description": "User profile data."
    },
    "/memberships/{membershipId}": {
      "schema": { "$ref": "#/entities/Membership" },
      "description": "User memberships to entities."
    },
    "/entities/{entityId}": {
      "schema": { "$ref": "#/entities/Entity" },
      "description": "Entity details."
    },
    "/entities/{entityId}/applicationForms/{formId}": {
      "schema": { "$ref": "#/entities/ApplicationForm" },
      "description": "Candidate application form configurations."
    },
    "/entities/{entityId}/applicationSubmissions/{submissionId}": {
      "schema": { "$ref": "#/entities/ApplicationSubmission" },
      "description": "Submissions from candidates."
    },
    "/entities/{entityId}/applicationSubmissionDedupe/{dedupeKey}": {
      "schema": { "type": "object" },
      "description": "Deduplication locks."
    }
  }
}